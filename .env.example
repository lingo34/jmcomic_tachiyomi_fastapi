# Copy to .env and adjust. All variables are optional; defaults are shown.

# --- Authentication -----------------------------------------------------------
# When REMOTEAPI_API_KEY is set, every request (except /health and
# /v1/capabilities) must carry the key in the configured header.
REMOTEAPI_API_KEY=
REMOTEAPI_API_HEADER=X-Api-Key

# --- jmcomic client -----------------------------------------------------------
JMCOMIC_IMPL=api
# Comma-separated override for jmcomic API domains.
JMCOMIC_DOMAIN_LIST=
# CDN domain used to build cover image URLs.
JMCOMIC_IMAGE_DOMAIN=
# Domain used when returning the manga detail URL.
JMCOMIC_HTML_DOMAIN=18comic.vip
# Disable jmcomic's verbose logging.
JMCOMIC_DISABLE_LOG=true
# Optional overrides for image request headers (used in direct-CDN mode).
JMCOMIC_IMAGE_REFERER=
JMCOMIC_UA=
# Default page size advertised in capabilities and used when clients omit it.
JMCOMIC_DEFAULT_PAGE_SIZE=40

# --- HTTP / security ----------------------------------------------------------
# Expose Swagger UI / ReDoc / openapi.json. Disable in production.
APP_DOCS_ENABLED=true
# Comma-separated Host allow-list. "*" disables Host checking.
APP_ALLOWED_HOSTS=*
# Comma-separated CORS origins. Empty disables CORS entirely.
APP_CORS_ALLOW_ORIGINS=
# Trust X-Forwarded-* headers and which proxy IPs may set them.
APP_PROXY_HEADERS=true
APP_FORWARDED_ALLOW_IPS=127.0.0.1

# --- Server / observability ---------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_RELOAD=false
# NOTE: there is no access-log toggle. The app never logs client IPs, request
# paths, or any request-identifying information, by design.

# --- Resource limits (tune for your host; defaults suit a 256 MB container) ----
# Max decoded image size (pixels). ~3 bytes/pixel per in-memory copy.
APP_MAX_IMAGE_PIXELS=20000000
# Max simultaneous image decodes (bounds peak memory).
APP_MAX_CONCURRENT_IMAGES=2
