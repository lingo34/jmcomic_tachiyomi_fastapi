# Local virtualenv (must be excluded so it never overwrites the built one)
.venv/

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Version control & docker meta
.git/
.github/
.gitignore
.dockerignore
.editorconfig
Dockerfile
docker-compose.yml

# Secrets / local config
.env
.env.*
.env.example

# Tests & docs (not needed in a runtime image; README is kept for build metadata)
tests/
docs/
